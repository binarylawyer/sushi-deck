{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@binarylawyer/sushi-deck": ["./src/index.ts"],
      "@binarylawyer/sushi-deck/json": ["./src/json/index.ts"],
      "@binarylawyer/sushi-deck/store": ["./src/store/index.ts"],
      "@binarylawyer/sushi-deck/gate": ["./src/gate/index.ts"]
    },
    "types": ["react", "react-dom", "node"]
  },
  "include": ["src", "examples"]
}
